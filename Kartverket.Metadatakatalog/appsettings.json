{
  "SolrServerUrl": "http://localhost:8983",
  "DownloadUrl": "https://localhost:44350/",
  "GeonorgeUrl": "https://www.test.geonorge.no/",
  "KartkatalogenUrl": "http://localhost:50081/",
  "Accessibilitystatementurl": "https://www.geonorge.no/tilgjengelighet/",
  "RegistryUrl": "https://register.dev.geonorge.no/",
  "GeoNetworkUrl": "https://www.geonorge.no/geonetworkdev/",
  "EditorUrl": "https://editor.dev.geonorge.no/",
  "MetUrl": "https://test.csw.met.no/csw?",
  "NorgeskartUrl": "https://geonorge-nkg.atkv3-dev.kartverket.cloud/geoportal/",
  "AppSettings": {
    "MaxRecursionLimit": "10000",
    "WebmasterEmail": "post@norgedigitalt.no",
    "SupportsMultiCulture": "true",
    "BuildVersionNumber": "1.0",
    "DownloadServiceEnabled": "true",
    "EnvironmentName": "dev",
    "WhitespaceFilterEnabled": "true"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Kartverket.Metadatakatalog": "Debug",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "fileSizeLimitBytes": 10485760,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Authentication": {
    "BearerToken": {
      "Authority": "https://your-auth-server.com",
      "Audience": "your-api"
    },
    "Cookie": {
      "ExpireTimeSpan": "01:00:00",
      "SlidingExpiration": true,
      "SecureCookies": false
    },
    "Jwt": {
      "Issuer": "https://geonorge.kartverket.no",
      "Audience": "kartkatalog-api",
      "SecretKey": "your-jwt-secret-key-here-must-be-at-least-32-characters-long"
    },
    "OpenIdConnect": {
      "Authority": "https://login.microsoftonline.com/your-tenant-id",
      "ClientId": "your-azure-ad-client-id",
      "ClientSecret": "your-azure-ad-client-secret"
    }
  },
  "Culture": {
    "DefaultCulture": "nb-NO",
    "SupportedCultures": [
      "nb-NO",
      "en-US"
    ],
    "CookieDomain": ".geonorge.no"
  },
  "Security": {
    "RequireHttps": false,
    "ValidHosts": [
      ".geonorge.no",
      "localhost"
    ]
  },
  "Kestrel": {
    "Limits": {
      "MaxRequestBodySize": 890000000,
      "RequestHeadersTimeout": "00:00:30"
    }
  },
  "AllowedHosts": "*"
}